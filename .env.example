# =============================================
# PATRIMOVE - Variáveis de Ambiente
# =============================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o arquivo .env no repositório.
# =============================================

# --- Banco de Dados ---
DATABASE_URL="postgresql://patrimove:patrimove@localhost:5432/patrimove?schema=public"

# --- NextAuth ---
NEXTAUTH_SECRET="gerar-com-openssl-rand-base64-32"
NEXTAUTH_URL="https://patrimove.jfap.jus.br"

# --- LDAP / Active Directory ---
LDAP_URL="ldap://ldap.jfap.jus.br:389"
LDAP_BIND_DN="cn=admin,dc=jfap,dc=jus,dc=br"
LDAP_BIND_PASSWORD=""
LDAP_SEARCH_BASE="dc=jfap,dc=jus,dc=br"
LDAP_SEARCH_FILTER="(sAMAccountName={{username}})"

# --- SMTP (E-mail) ---
SMTP_HOST="smtp.jfap.jus.br"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="patrimove@jfap.jus.br"

# --- Aplicação ---
APP_URL="https://patrimove.jfap.jus.br"
TOKEN_EXPIRY_DAYS="7"
