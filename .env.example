# =============================================
# PATRIMOVE - Variáveis de Ambiente
# =============================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o arquivo .env no repositório.
# =============================================

# --- Banco de Dados ---
DATABASE_URL="postgresql://simap:simap@localhost:5432/simap?schema=public"

# --- NextAuth ---
NEXTAUTH_SECRET="gerar-com-openssl-rand-base64-32"
NEXTAUTH_URL="https://patrimove.jfap.jus.br"

# --- LDAP / Active Directory ---
# Com LDAP_URL vazio, o login só exige Usuario ativo no banco (útil para CI/dev).
# Em produção: preencha URL, BIND e BASE. ldaps:// usa TLS na porta 636.
LDAP_URL="ldap://ldap.jfap.jus.br:389"
LDAP_BIND_DN="cn=admin,dc=jfap,dc=jus,dc=br"
LDAP_BIND_PASSWORD=""
LDAP_SEARCH_BASE="dc=jfap,dc=jus,dc=br"
LDAP_SEARCH_FILTER="(sAMAccountName={{username}})"
# Normalização da matrícula no filtro: upper (padrão) | lower | none
LDAP_USERNAME_CASE="upper"
# Tempos em ms (opcional)
LDAP_TIMEOUT_MS="10000"
LDAP_CONNECT_TIMEOUT_MS="8000"
# ldaps com certificado interno: "false" desativa verificação (apenas se necessário)
LDAP_TLS_REJECT_UNAUTHORIZED="true"
# Perfil inicial ao provisionar Usuario no primeiro login (LDAP): TECNICO_TI | SERVIDOR_RESPONSAVEL | SERVIDOR_SEMAP | GESTOR_ADMIN
LDAP_DEFAULT_PROVISION_PERFIL="SERVIDOR_RESPONSAVEL"

# --- SMTP (E-mail) ---
SMTP_HOST="smtp.jfap.jus.br"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="patrimove@jfap.jus.br"

# --- Aplicação ---
APP_URL="https://patrimove.jfap.jus.br"
TOKEN_EXPIRY_DAYS="7"
