# =============================================
# PATRIMOVE - Variáveis de Ambiente (exemplo)
# =============================================

# --- Banco de Dados ---
POSTGRES_USER="simap"
POSTGRES_PASSWORD="simap_forte"
POSTGRES_DB="simap"
DATABASE_URL="postgresql://simap:simap_forte@localhost:5432/simap?schema=public"

# --- Aplicação ---
APP_PORT="3000"
APP_URL="http://localhost:3000"
TOKEN_EXPIRY_DAYS="7"
APP_DOMAIN="simap.intra.jfap"

# --- NextAuth ---
NEXTAUTH_SECRET="gerar-com-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# --- LDAP / Active Directory ---
# LDAP_URL="ldap://ldap.jfap.jus.br:389"
# LDAP_BIND_DN="cn=admin,dc=jfap,dc=jus,dc=br"
# LDAP_BIND_PASSWORD=""
# LDAP_SEARCH_BASE="dc=jfap,dc=jus,dc=br"
# LDAP_SEARCH_FILTER="(sAMAccountName={{username}})"
# LDAP_USERNAME_CASE="upper"
# LDAP_TIMEOUT_MS="10000"
# LDAP_CONNECT_TIMEOUT_MS="8000"
# LDAP_TLS_REJECT_UNAUTHORIZED="true"
# LDAP_DEFAULT_PROVISION_PERFIL="SERVIDOR_RESPONSAVEL"

# --- SMTP (E-mail) ---
SMTP_HOST="smtp.jfap.jus.br"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="simap@jfap.jus.br"

# --- Backup do banco (somente producao) ---
# Retencao em dias para os dumps em deploy/backups/.
BACKUP_RETENTION_DAYS="14"
# Intervalo entre dumps em segundos (86400 = 24h).
BACKUP_INTERVAL_SECONDS="86400"
