# Default: detect text vs binary, normalize line endings on commit.
* text=auto

# Scripts e arquivos que rodam em Linux precisam de LF, sempre.
*.sh         text eol=lf
*.bash       text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.template   text eol=lf
*.conf       text eol=lf
*.toml       text eol=lf
Dockerfile   text eol=lf
.dockerignore text eol=lf
.gitignore   text eol=lf
.gitattributes text eol=lf
.env*        text eol=lf

# Scripts Windows mantêm CRLF.
*.cmd        text eol=crlf
*.bat        text eol=crlf
*.ps1        text eol=crlf

# Binários: nunca tocar.
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.pdf        binary
*.zip        binary
*.gz         binary
*.tar        binary
*.tgz        binary
*.woff       binary
*.woff2      binary
*.ttf        binary
*.otf        binary
*.eot        binary
*.wasm       binary
